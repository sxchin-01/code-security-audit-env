# LLM provider: hf | gemini
LLM_PROVIDER=gemini
STRICT_MODE=0

# Hugging Face API Configuration (used when LLM_PROVIDER=hf)
HF_API_KEY=hf_your_token_here
HF_MODEL=deepseek-ai/DeepSeek-R1:fastest
HF_DEBUG_RESPONSE=0

# Gemini API Configuration (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_DEBUG_RESPONSE=0
